# LLM — OpenAI (recommended)
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# Alternative: Groq (fast/cheap for local dev)
# LLM_PROVIDER=groq
# LLM_API_KEY=your_groq_key_here
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1

# App
APP_PORT=8000
LOG_LEVEL=INFO

# Neon PostgreSQL — use a dedicated database per project (e.g. /inkflow not /neondb)
# Example: postgresql://user:pass@ep-xxx.aws.neon.tech/inkflow?sslmode=require
DATABASE_URL=
